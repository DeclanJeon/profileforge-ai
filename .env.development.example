# Copy to .env.development.local for local development.
DATABASE_URL="file:./db/custom.db"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-nextauth-secret-change-me"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
PROFILEFORGE_IMAGE_PROVIDER_HOST="ponslink"
PROFILEFORGE_IMAGE_PROVIDER_BIN="/home/declan/bin/codex-imagen"
PROFILEFORGE_IMAGE_PROVIDER_TIMEOUT_SECONDS="900"
PROFILEFORGE_GENERATION_CONCURRENCY="1"
PROFILEFORGE_USER_ACTIVE_JOB_LIMIT="1"
PROFILEFORGE_DEFAULT_RESULT_COUNT="1"
PROFILEFORGE_MAX_RESULT_COUNT="4"
PROFILEFORGE_IMAGE_TIMEOUT_SECONDS="900"
PROFILEFORGE_JOB_TIMEOUT_SECONDS="3600"
PROFILEFORGE_QUEUE_STALE_RUNNING_SECONDS="5400"
PROFILEFORGE_AVERAGE_IMAGE_SECONDS="360"
PROFILEFORGE_WORKER_SECRET="dev-worker-secret-change-if-exposed"
PROFILEFORGE_GENERATED_IMAGE_DIR="/tmp/profileforge-generated-dev"
PROFILEFORGE_GENERATED_IMAGE_TTL_SECONDS="600"
PROFILEFORGE_UPLOAD_TTL_SECONDS="1800"
PROFILEFORGE_DOWNLOAD_TOKEN_TTL_HOURS="24"
PROFILEFORGE_MAX_DOWNLOADS_PER_TOKEN="10"
PROFILEFORGE_TOKEN_PEPPER="profileforge-dev-token-pepper-change-me"
PROFILEFORGE_ENABLE_R2_STORAGE="false"
PROFILEFORGE_R2_ACCOUNT_ID=""
PROFILEFORGE_R2_ACCESS_KEY_ID=""
PROFILEFORGE_R2_SECRET_ACCESS_KEY=""
PROFILEFORGE_R2_BUCKET="profileforge-generated-dev"
PROFILEFORGE_R2_ENDPOINT=""
PROFILEFORGE_R2_SIGNED_URL_TTL_SECONDS="300"
PROFILEFORGE_R2_OBJECT_TTL_HOURS="24"
PROFILEFORGE_EMAIL_PROVIDER="resend"
PROFILEFORGE_EMAIL_FROM="ProfileForge Dev <noreply@profileforge.ponslink.com>"
PROFILEFORGE_EMAIL_REPLY_TO="support@profileforge.ponslink.com"
PROFILEFORGE_EMAIL_API_KEY=""
# SMTP alternative. Set PROFILEFORGE_EMAIL_PROVIDER="smtp" and fill these instead of Resend.
PROFILEFORGE_SMTP_HOST=""
PROFILEFORGE_SMTP_PORT="587"
PROFILEFORGE_SMTP_USER=""
PROFILEFORGE_SMTP_PASS=""
PROFILEFORGE_SMTP_SECURE="false"
PROFILEFORGE_DOWNLOAD_BASE_URL="http://localhost:3000/download"
PROFILEFORGE_RESEND_EMAIL_COOLDOWN_SECONDS="60"
PROFILEFORGE_DAILY_GLOBAL_IMAGE_LIMIT="1000"
PROFILEFORGE_DAILY_EMAIL_IMAGE_LIMIT="100"
PROFILEFORGE_DAILY_IP_IMAGE_LIMIT="100"
