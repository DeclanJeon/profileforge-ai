# Database
DATABASE_URL="file:./db/custom.db"

# Image generation adapter integration
PROFILEFORGE_IMAGE_PROVIDER_HOST="ponslink"
PROFILEFORGE_IMAGE_PROVIDER_BIN="$HOME/bin/image-adapter"
PROFILEFORGE_IMAGE_PROVIDER_TIMEOUT_SECONDS="900"

# Ephemeral generated-image retention
PROFILEFORGE_GENERATED_IMAGE_DIR="/tmp/profileforge-generated"
PROFILEFORGE_GENERATED_IMAGE_TTL_SECONDS="600"
PROFILEFORGE_UPLOAD_TTL_SECONDS="1800"
